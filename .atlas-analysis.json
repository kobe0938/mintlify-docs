  "keyFeatures": [
    "Run evals on popular benchmarks (Terminal-Bench, SWE-Bench) with a single CLI command",
    "Horizontal scaling via cloud sandbox providers (Daytona, Modal, E2B, Runloop, and more)",
    "Pre-integrated popular agents: Terminus-2, Claude Code, Gemini CLI, Codex CLI, OpenHands, and more",
    "Flexible task format with Docker-based environments, test scripts, and reward files",
    "Reward Kit for defining programmatic and LLM-as-judge verifiers",
    "SFT dataset export from agent trajectories with Hugging Face Hub push support",
    "RL rollout interface with support for SkyRL and vLLM-based training workflows",
    "Harbor Hub for storing, sharing, and comparing evaluation jobs",
    "Skills system for injecting reusable context into agent trials",
    "Multi-step tasks, network policies, and resource management per task"
  ],
  "publicApiSurface": [
    "harbor run -d <org/dataset> -m <model> -a <agent>",
    "harbor dataset list",
    "harbor init --task <org/name>",
    "harbor view jobs",
    "harbor traces export",
    "harbor sweeps run",
    "harbor hub job list",
    "harbor hub job show <job_id>",
    "harbor hub job compare <job_id_1> <job_id_2>",
    "BaseAgent (Python interface)",
    "BaseInstalledAgent (Python interface)",
    "JobConfig / TrialConfig / TaskConfig (Python classes)",
    "rewardkit CLI and Python API (rk.run, rk.discover, @criterion decorator)",
    "task.toml configuration schema",
    "ATIF trajectory format"
  ]
